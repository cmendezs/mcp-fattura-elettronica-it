# mcp-fattura-elettronica-it — Environment configuration
# Copy this file to .env and adjust values as needed.

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Path to the FatturaPA XSD schema file (relative to project root)
# Override only if you place the XSD in a custom location.
FATTURA_XSD_PATH=schemas/FatturaPA_v1.6.1.xsd
